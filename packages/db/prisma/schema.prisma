generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User and session info for NextAuth (Admin dashboard)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("ADMIN")
  accounts      Account[]
  sessions      Session[]
  polls         Poll[]
  comments      Comment[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Poller specific models
model Poll {
  id                 String       @id @default(cuid())
  title              String
  description        String?
  expiresAt          DateTime?
  allowMultipleVotes Boolean      @default(false)
  
  // Advanced Settings
  requireNames       Boolean      @default(false)
  hasOtherOption     Boolean      @default(false)
  allowComments      Boolean      @default(false)
  hideShareButton    Boolean      @default(false)
  anonymizeData      Boolean      @default(false)
  resultsVisibility  String       @default("PUBLIC") // PUBLIC, HIDDEN, ADMIN_ONLY

  createdAt          DateTime     @default(now())
  
  creatorId          String?
  creator            User?        @relation(fields: [creatorId], references: [id])

  options            PollOption[]
  votes              Vote[]
  comments           Comment[]
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  text      String
  
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     Vote[]
}

model Vote {
  id              String   @id @default(cuid())
  pollId          String
  optionId        String
  
  // Tracking fields for duplicate prevention
  fingerprintHash String
  ipAddress       String
  userAgent       String?
  
  // Advanced features
  voterName       String?
  customAnswer    String?

  createdAt       DateTime @default(now())

  poll            Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option          PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  pollId    String
  text      String
  authorName String?
  authorId  String?
  createdAt DateTime @default(now())

  poll      Poll?     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])
}
